# Copy this file to .env and adjust as needed:  cp .env.example .env

# --- MongoDB ---
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=example
MONGO_DB=ocpp_emulator
MONGO_PORT=27017

# --- Backend (NestJS) ---
BACKEND_PORT=3000

# --- Auth (JWT) ---
# Only used once a user locks the instance. Change the secret in production.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
